# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Brave Search API key — used for recipe link discovery.
# Sign up for a free key at https://api.search.brave.com
# Free tier: 2,000 queries/month. No key = falls back to Bing RSS.
BRAVE_API_KEY=

# Kroger session cookie — required for live weekly ad capture.
# Copy the full Cookie header value from browser DevTools while browsing kroger.com.
KROGER_COOKIE=

# Optional: Kroger weekly circular UUID (overrides automatic detection).
KROGER_CIRCULAR_ID=

# Optional: persistent Chromium profile directory for Kroger Playwright capture.
KROGER_BROWSER_PROFILE_DIR=

# Optional: Playwright browser channel for Kroger capture (e.g. chrome).
KROGER_BROWSER_CHANNEL=
